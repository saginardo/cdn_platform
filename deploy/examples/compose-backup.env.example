BACKUP_TIME=03:25
BACKUP_RANDOM_DELAY_SECONDS=1200
CONTROL_DATA_DIR=/var/lib/cdn-platform
CONTROL_TLS_DIR=/var/lib/cdn-control-tls
BACKUP_STAGING_DIR=/backup/staging
CLICKHOUSE_URL=http://127.0.0.1:8123
CLICKHOUSE_DATABASE=cdn_platform
RESTIC_REPOSITORY=s3:https://s3.example.com/cdn-platform-backups
RESTIC_PASSWORD_FILE=/deployment/config/restic-password
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
