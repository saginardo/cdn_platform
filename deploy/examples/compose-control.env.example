CONTROL_ENCRYPTION_KEY=
CONTROL_DATA_DIR=/var/lib/cdn-platform
CONTROL_LISTEN=:8443
CONTROL_PUBLIC_URL=https://control.example.com
EDGE_CONTROL_URL=https://control.example.com:8443
CONTROL_TLS_DOMAIN=control.example.com
CONTROL_TLS_CERT=/var/lib/cdn-control-tls/live/control.example.com/fullchain.pem
CONTROL_TLS_KEY=/var/lib/cdn-control-tls/live/control.example.com/privkey.pem
SETUP_ALLOW_CIDRS=198.51.100.42/32
TRUSTED_PROXY_CIDRS=127.0.0.1/32

CLOUDFLARE_API_TOKEN=
ACME_EMAIL=admin@example.com
CERTIFICATE_ISSUE_TIMEOUT=10m

EDGE_BINARY_URL=https://control.example.com/downloads/cdn-edge-agent-linux-amd64
EDGE_BINARY_PATH=/usr/local/lib/cdn-platform/cdn-edge-agent-linux-amd64
# Optional. The controller calculates this digest and rejects a mismatched value.
EDGE_BINARY_SHA256=

CLICKHOUSE_URL=http://127.0.0.1:8123
CLICKHOUSE_DATABASE=cdn_platform
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DISABLED=0

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=cdn-control@example.com
SMTP_TO=
