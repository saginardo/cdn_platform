# Generate once: /usr/local/bin/cdn-control keygen
CONTROL_ENCRYPTION_KEY=
CONTROL_DATA_DIR=/var/lib/cdn-platform
CONTROL_LISTEN=:443
CONTROL_PUBLIC_URL=https://control.example.com
# Optional direct HTTPS endpoint for edge mTLS when the UI is behind a reverse proxy.
EDGE_CONTROL_URL=
CONTROL_TLS_SOURCE_CERT=/etc/letsencrypt/live/control.example.com/fullchain.pem
CONTROL_TLS_SOURCE_KEY=/etc/letsencrypt/live/control.example.com/privkey.pem
CONTROL_TLS_CERT=/run/cdn-platform/control.crt
CONTROL_TLS_KEY=/run/cdn-platform/control.key
# Optional but recommended before first public startup.
SETUP_ALLOW_CIDRS=198.51.100.42/32
# Honor X-Real-IP only when the TCP peer belongs to one of these reverse proxies.
TRUSTED_PROXY_CIDRS=

# Use a scoped token with Zone:Read and DNS:Edit only for managed Zones.
CLOUDFLARE_API_TOKEN=
ACME_EMAIL=admin@example.com
# Maximum wall-clock time for one asynchronous DNS-01 Certbot run.
CERTIFICATE_ISSUE_TIMEOUT=10m

# HTTPS URL of a signed linux-amd64 edge-agent binary that the controller may expose in copyable enrollment commands.
EDGE_BINARY_URL=https://releases.example.com/cdn-edge-agent-linux-amd64
EDGE_BINARY_SHA256=
# Optional local path exposed at /downloads/cdn-edge-agent-linux-amd64.
EDGE_BINARY_PATH=

CLICKHOUSE_URL=http://127.0.0.1:8123
CLICKHOUSE_DATABASE=cdn_platform
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
# Set to 1 on constrained control hosts that do not run ClickHouse.
CLICKHOUSE_DISABLED=0

# Optional alerting. Leave SMTP_TO blank to disable outbound alerts.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=cdn-control@example.com
SMTP_TO=
