<clickhouse>
  <logger>
    <level>warning</level>
    <size>100M</size>
    <count>3</count>
  </logger>
  <!-- Keep ClickHouse private to the control host. -->
  <listen_host>127.0.0.1</listen_host>
  <listen_host>::1</listen_host>
  <!-- Keep background scheduling proportional to the 2-core control VPS. -->
  <background_schedule_pool_size>16</background_schedule_pool_size>
  <!-- Suitable for the 4 GiB control VPS; adjust before higher traffic. -->
  <max_server_memory_usage>1200000000</max_server_memory_usage>
  <!-- Disable high-volume diagnostic logs that otherwise merge continuously. -->
  <metric_log remove="1"/>
  <asynchronous_metric_log remove="1"/>
  <trace_log remove="1"/>
  <text_log remove="1"/>
  <processors_profile_log remove="1"/>
  <background_schedule_pool_log remove="1"/>
  <query_views_log remove="1"/>
  <query_metric_log remove="1"/>
  <instrumentation_trace_log remove="1"/>
  <total_memory_profiler_step>0</total_memory_profiler_step>
</clickhouse>
