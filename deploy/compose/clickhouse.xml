<clickhouse>
  <logger>
    <level>warning</level>
    <size>100M</size>
    <count>3</count>
  </logger>
  <listen_host>0.0.0.0</listen_host>
  <background_schedule_pool_size>16</background_schedule_pool_size>
  <max_server_memory_usage>1200000000</max_server_memory_usage>
  <metric_log remove="1"/>
  <asynchronous_metric_log remove="1"/>
  <trace_log remove="1"/>
  <text_log remove="1"/>
  <processors_profile_log remove="1"/>
  <background_schedule_pool_log remove="1"/>
  <query_views_log remove="1"/>
  <query_metric_log remove="1"/>
  <instrumentation_trace_log remove="1"/>
  <total_memory_profiler_step>0</total_memory_profiler_step>
  <storage_configuration>
    <disks>
      <backups>
        <type>local</type>
        <path>/var/lib/clickhouse/backups/</path>
      </backups>
    </disks>
  </storage_configuration>
  <backups>
    <allowed_disk>backups</allowed_disk>
    <remove_backup_files_after_failure>true</remove_backup_files_after_failure>
  </backups>
</clickhouse>
