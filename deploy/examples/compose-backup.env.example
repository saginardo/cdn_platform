# Bootstrap and disaster-recovery fallback values. An authenticated Settings
# override in the control database takes precedence during normal operation.
BACKUP_TIME=03:25
BACKUP_RANDOM_DELAY_SECONDS=1200
BACKUP_MAX_ATTEMPTS=3
BACKUP_RETRY_DELAYS_SECONDS=30,120
CONTROL_DATA_DIR=/var/lib/cdn-platform
CONTROL_TLS_DIR=/var/lib/cdn-control-tls
BACKUP_STAGING_DIR=/backup/staging
CLICKHOUSE_URL=http://127.0.0.1:8123
CLICKHOUSE_DATABASE=simple_cdn
RESTIC_REPOSITORY=s3:https://s3.example.com/simple-cdn-backups
# The referenced password file is the fallback; keep an offline recovery copy.
RESTIC_PASSWORD_FILE=/deployment/config/restic-password
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
